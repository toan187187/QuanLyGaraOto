<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.doan123.Controller.LoginController">
    <children>
        <VBox alignment="TOP_CENTER" prefHeight="550.0" prefWidth="400.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Rectangle arcHeight="5.0" arcWidth="5.0" fill="#2D3447" height="65.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="400.0" />

                <VBox fx:id="formBox" alignment="CENTER" prefHeight="450.0" prefWidth="100.0" spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
                    </padding>
                    <children>
                        <Label text="TẠO TÀI KHOẢN" textFill="#2d3447">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>

                        <TextField fx:id="txtHoTenDK" prefHeight="40.0" promptText="Họ và Tên" style="-fx-background-radius: 30; -fx-padding: 10;" />

                        <TextField fx:id="txtTenDangNhapDK" prefHeight="40.0" promptText="Tên đăng nhập" style="-fx-background-radius: 30; -fx-padding: 10;" />

                        <PasswordField fx:id="txtMatKhauDK" prefHeight="40.0" promptText="Mật khẩu" style="-fx-background-radius: 30; -fx-padding: 10;" />

                        <PasswordField fx:id="txtNhapLaiMatKhauDK" prefHeight="40.0" promptText="Nhập lại mật khẩu" style="-fx-background-radius: 30; -fx-padding: 10;" />

                        <ComboBox fx:id="cbVaiTroDK" prefHeight="40.0" prefWidth="320.0" promptText="-- Chọn vai trò --" style="-fx-background-radius: 30; -fx-padding: 5;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="ADMIN" />
                                    <String fx:value="THO" />
                                    <String fx:value="LE_TAN" />
                                </FXCollections>
                            </items>
                        </ComboBox>

                        <Button onAction="#handleDangKy" prefHeight="45.0" prefWidth="320.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 30; -fx-font-weight: bold; -fx-cursor: hand;" text="ĐĂNG KÝ NGAY">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>

                        <Button onAction="#handleQuayLaiLogin" prefHeight="30.0" prefWidth="320.0" style="-fx-background-color: transparent; -fx-text-fill: #2c3e50; -fx-cursor: hand; -fx-underline: true;" text="Quay lại Đăng nhập" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>