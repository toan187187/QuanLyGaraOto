<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Priority?>

<HBox spacing="16" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.doan123.Controller.ThanhToanController"
      style="-fx-padding: 20;">

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <Label text="Danh sách xe chờ thanh toán:"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;"/>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtTimKiem" prefHeight="30.0" prefWidth="200.0"
                           promptText="🔍 Gõ biển số tìm nhanh..."
                           style="-fx-background-radius: 15; -fx-border-radius: 15;" />
            </children>
        </HBox>
        <TableView fx:id="tableXeCho" VBox.vgrow="ALWAYS"
                   prefHeight="560" maxWidth="1.7976931348623157E308">
            <columns>
                <TableColumn fx:id="colBienSo"    prefWidth="150" text="Biển Số Xe"/>
                <TableColumn fx:id="colTongTien"  prefWidth="180" text="Tổng Tiền (VNĐ)"/>
            </columns>
        </TableView>
    </VBox>

    <VBox spacing="20" prefWidth="480" minWidth="400"
          style="-fx-background-color: #ecf0f1;
                 -fx-background-radius: 10;
                 -fx-padding: 24;">

        <Label text="THÔNG TIN HÓA ĐƠN"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label prefWidth="180" text="Biển số xe:"
                   style="-fx-font-size: 15px;"/>
            <Label fx:id="lblBienSo" text="..."
                   style="-fx-font-size: 15px; -fx-font-weight: bold;
                          -fx-text-fill: #2980b9;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label prefWidth="180" text="Tổng tiền phải thu:"
                   style="-fx-font-size: 15px;"/>
            <Label fx:id="lblTongTien" text="0 VNĐ"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #c0392b;"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label prefWidth="180" text="Tiền khách đưa:"
                   style="-fx-font-size: 15px;"/>
            <TextField fx:id="txtTienKhachDua"
                       promptText="Nhập số tiền..."
                       style="-fx-font-size: 14px;"
                       HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label prefWidth="180" text="Tiền thừa trả lại:"
                   style="-fx-font-size: 15px;"/>
            <Label fx:id="lblTienThua" text="0 VNĐ"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #27ae60;"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS"/>

        <Button fx:id="btnXacNhan"
                text="✅ XÁC NHẬN THANH TOÁN &amp; XUẤT XE"
                maxWidth="1.7976931348623157E308"
                prefHeight="50"
                style="-fx-background-color: #27ae60;
                       -fx-text-fill: white;
                       -fx-font-size: 15px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"/>
    </VBox>
</HBox>