<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.doan123.Controller.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="200.0" spacing="20.0" styleClass="header-section" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label styleClass="logo-text" text="🚗 QUẢN LÝ GARA Ô TÔ " />
                <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                <Label text="👤 Admin" textFill="WHITE" />
            </children>
        </HBox>
    </top>
    <left>
        <VBox prefHeight="200.0" prefWidth="200.0" spacing="10.0" styleClass="sidebar-section" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="btnMenuTiepNhan" maxWidth="1.7976931348623157E308" onMouseClicked="#onTiepNhan" styleClass="menu-button" text="📝 Tiếp nhận" />
                <Label fx:id="btnMenuSuaChua" maxWidth="1.7976931348623157E308" onMouseClicked="#onSuaChua" styleClass="menu-button" text="🔧 Sửa chữa  " />
                <Label fx:id="btnMenuKhoHang" onMouseClicked="#onKhoHang" prefHeight="47.0" prefWidth="201.0" styleClass="menu-button" text="📦 Kho hàng" />
                <Label fx:id="btnMenuThanhToan" maxWidth="1.7976931348623157E308" onMouseClicked="#onThanhToan" styleClass="menu-button" text="💳 Thanh toán" />
                <Label fx:id="btnMenuBaoCao" onMouseClicked="#onBaoCao" prefWidth="201.0" styleClass="menu-button" text="📊 Báo cáo"/>
                <Label maxWidth="1.7976931348623157E308" onMouseClicked="#onDangXuat" styleClass="menu-button" text="🚪 Đăng xuất">
                    <cursor>
                        <Cursor fx:constant="HAND" />
                    </cursor></Label>
            </children>
            <padding>
                <Insets top="20.0" />
            </padding>
        </VBox>
    </left>
    <center>
        <AnchorPane fx:id="contentArea" prefHeight="0.0" prefWidth="200.0" styleClass="main-content" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
            <children>
                <Label layoutX="278.0" layoutY="253.0" text="👉 XIN CHÀO, VUI LÒNG CHỌN CHỨC NĂNG " />
            </children>
        </AnchorPane>
    </center>
</BorderPane>
